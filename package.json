{
  "scripts": {
    "biome": "biome lint",
    "eslint": "eslint . --debug --color",
    "oxlint": "oxlint --type-aware",
    "build": "node build.ts",
    "server": "node ./dist/index.js",
    "tsc": "tsc",
    "kysely-codegen": "kysely-codegen --config-file kysely_config.json"
  },
  "scriptsmon": {
      "kysely-codegen":"kysely_config.json",
      "lint": [
        "src",
        "biome.json",
        "tsconfig.json"
      ],
      "biome": [
        "$lint",
        "biome.json"
      ],
      "eslint": [
        "$lint",
        "eslint.config.mjs"
      ],
      "oxlint": [
        "$lint",
        ".oxlintrc.json"
      ],
      "build": [
        "src",
        "package.json",
        "build.ts"
      ],
      "tsc": [
        "$lint"
      ],
      "server":"./dist/index.js"
    
  },
  "dependencies": {
    "@fastify/cookie": "11.0.2",
    "@fastify/static": "9.0.0",
    "fastify": "5.6.2",
    "kysely": "0.28.9",
    "marked": "17.0.1",
    "mysql2": "3.16.0",
    "varlog": "1.0.5",
    "xmlbuilder2": "^4.0.3",
    "zod": "4.2.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.10",
    "@eslint/css": "0.14.1",
    "@eslint/js": "9.39.2",
    "@types/node": "25.0.3",
    "esbuild": "0.27.2",
    "eslint": "9.39.2",
    "eslint-formatter-visualstudio": "9.0.1",
    "eslint-import-resolver-typescript": "4.4.4",
    "eslint-plugin-import-x": "4.16.1",
    "globals": "16.5.0",
    "kysely-codegen": "0.19.0",
    "oxlint": "1.36.0",
    "oxlint-tsgolint": "0.10.0",
    "type-fest": "5.3.1",
    "typescript": "5.9.3",
    "typescript-eslint": "8.51.0"
  }
}
