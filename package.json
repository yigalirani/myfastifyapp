{
  "type":"module",
  "scripts": {
    "biome": "biome lint",
    "eslint": "eslint . --color",
    "oxlint": "oxlint --type-aware",
    "build": "node build.ts",
    "server": "node ./dist/index.js",
    "tsc": "tsc",
    "kysely-codegen": "kysely-codegen --config-file kysely_config.json"
  },
  "scriptsmon": {
    "kysely-codegen": "kysely_config.json",
    "lint": [
      "src/autogen/*.ts",
      "src/*.ts",
      "biome.json",
      "tsconfig.json"
    ],
    "biome": [
      "$lint",
      "biome.json"
    ],
    "eslint": [
      "$lint",
      "eslint.config.mjs"
    ],
    "oxlint": [
      "$lint",
      ".oxlintrc.json"
    ],
    "build": [
      "src/*.ts",
      "package.json",
      "build.ts"
    ],
    "tsc": [
      "$lint"
    ],
    "server": "./dist/index.js"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@eslint/css": "1.3.0",
    "@eslint/js": "10.0.1",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "25.9.1",
    "esbuild": "0.28.0",
    "eslint": "^10",
    "eslint-formatter-visualstudio": "9.0.1",
    "eslint-import-resolver-typescript": "4.4.5",
    "eslint-plugin-import-x": "4.16.2",
    "globals": "17.6.0",
    "kysely-codegen": "0.20.0",
    "oxlint": "1.68.0",
    "oxlint-tsgolint": "0.23.0",
    "type-fest": "5.7.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.60.1"
  },
  "dependencies": {
    "@fastify/cookie": "11.0.2",
    "@fastify/static": "9.1.3",
    "fastify": "5.8.5",
    "kysely": "0.29.2",
    "lodash-es": "^4.18.1",
    "marked": "18.0.5",
    "mysql2": "3.22.4",
    "varlog": "1.0.5",
    "xmlbuilder2": "^4.0.3",
    "zod": "4.4.3"
  }
}
